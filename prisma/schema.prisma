// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Acesso
  hasBasicAccess Boolean   @default(false)
  planType       String?   // "monthly" | "yearly" | "lifetime"
  planExpiresAt  DateTime? // null para lifetime

  // Gamificação
  xp             Int @default(0) // XP atual no level (reseta ao subir)
  level          Int @default(0)
  totalXpAllTime Int @default(0) // nunca decrementa — usado no ranking

  // Customização
  equippedSkinId String @default("default")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações Auth.js
  accounts Account[]
  sessions Session[]

  // Relações app
  purchases Purchase[]
  skins     UserSkin[]
  xpEvents  XpEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Purchase {
  id                  String  @id @default(cuid())
  userId              String
  infinitepayOrderNsu String? @unique // orderNsu enviado na criação
  infinitepaySlug     String? // invoice_slug do webhook
  infinitepayTxNsu    String? // transaction_nsu do webhook

  type     String // "basic_access" | "skin"
  planType String? // "monthly" | "yearly" | "lifetime"
  itemId   String? // skinId quando type = "skin"

  status     String   @default("pending") // "pending" | "paid" | "canceled"
  amount     Int // em centavos
  paidAmount Int? // valor confirmado pelo webhook

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([infinitepayOrderNsu])
  @@index([status])
}

model UserSkin {
  id         String   @id @default(cuid())
  userId     String
  skinId     String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skinId])
  @@index([userId])
}

model XpEvent {
  id     String @id @default(cuid())
  userId String
  amount Int
  reason String // "calc_operation" | "session_bonus" | "daily_login" | "welcome_bonus"

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
