# ==========================================
# 1. BANCO DE DADOS (Railway + Prisma)
# ==========================================
DATABASE_URL="postgresql://usuario:senha@host:port/nome_do_banco?schema=public"

# ==========================================
# 2. AUTENTICAÇÃO (Auth.js / NextAuth v5)
# ==========================================
AUTH_SECRET="sua_string_secreta_super_segura_aqui"
# Gere com: npx auth secret

AUTH_URL="http://localhost:3000"
# Em produção: https://seu-dominio.railway.app

# (Opcional) Login com Google
AUTH_GOOGLE_ID="seu_client_id_do_google"
AUTH_GOOGLE_SECRET="seu_client_secret_do_google"

# ==========================================
# 3. PAGAMENTOS (Pagar.me)
# ==========================================
PAGARME_SECRET_KEY="sk_test_sua_chave_secreta_aqui"
NEXT_PUBLIC_PAGARME_PUBLIC_KEY="pk_test_sua_chave_publica_aqui"
PAGARME_WEBHOOK_SECRET="wh_sec_seu_segredo_de_webhook_aqui"

# ==========================================
# 4. APP CONFIG
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
