# ==========================================
# 1. BANCO DE DADOS (Railway + Prisma)
# ==========================================
DATABASE_URL="postgresql://user:password@host:port/dbname"

# ==========================================
# 2. AUTENTICAÇÃO (Auth.js / NextAuth v5)
# ==========================================
AUTH_SECRET="seu-secret-aqui-gere-com-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Em produção: AUTH_URL="https://seu-dominio.vercel.app"

AUTH_GOOGLE_ID="seu-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-seu-google-secret"

# ==========================================
# 3. PAGAMENTOS (InfinitePay)
# ==========================================
INFINITEPAY_HANDLE="seu-handle-infinitepay"

# ==========================================
# 4. APP CONFIG
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Em produção: NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"
